# ── Server ────────────────────────────────────────────────
APP_CONFIG__SERVER__APP_PATH=app.main:app
APP_CONFIG__SERVER__HOST=0.0.0.0
APP_CONFIG__SERVER__PORT=8000
APP_CONFIG__SERVER__RELOAD=true

# ── Database ──────────────────────────────────────────────
APP_CONFIG__DATABASE__URL=postgresql+asyncpg://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB>
APP_CONFIG__DATABASE__TEST_URL=postgresql+asyncpg://<USER>:<PASSWORD>@<HOST>:<PORT>/<TEST_DB>
APP_CONFIG__DATABASE__ECHO=false
APP_CONFIG__DATABASE__ECHO_POOL=false
APP_CONFIG__DATABASE__POOL_SIZE=50
APP_CONFIG__DATABASE__MAX_OVERFLOW=10

# ── JWT ───────────────────────────────────────────────────
APP_CONFIG__JWT__ACCESS_TOKEN_SECRET=
APP_CONFIG__JWT__REFRESH_TOKEN_SECRET=
APP_CONFIG__JWT__ACCESS_TOKEN_EXPIRES_MINUTES=30
APP_CONFIG__JWT__REFRESH_TOKEN_EXPIRES_DAYS=7
APP_CONFIG__JWT__ALGORITHM=HS256

# ── CORS ─────────────────────────────────────────────────
APP_CONFIG__CORS__ORIGINS=["http://localhost:5173"]
APP_CONFIG__CORS__ALLOW_CREDENTIALS=true
APP_CONFIG__CORS__ALLOW_METHODS=["*"]
APP_CONFIG__CORS__ALLOW_HEADERS=["*"]

# ── Admin seed (RBAC) ─────────────────────────────────────
APP_CONFIG__ADMIN__USERNAME=admin
APP_CONFIG__ADMIN__PASSWORD=admin
APP_CONFIG__ADMIN__FULL_NAME=System Administrator

# ── PostgreSQL (used by docker-compose) ───────────────────
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
