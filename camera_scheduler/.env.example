# Database — used by both compose Postgres service and the app.
POSTGRES_USER=sharq
POSTGRES_PASSWORD=sharq
POSTGRES_DB=sharq
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional: full URL overrides POSTGRES_* above. Must be asyncpg driver.
# DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/postgres

# Engine pool tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Logging
LOG_LEVEL=INFO

# Run a one-shot fetch_access_logs("day") on startup. Useful in dev, off in prod.
RUN_ON_STARTUP=false
